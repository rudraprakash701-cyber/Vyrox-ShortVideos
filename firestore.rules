rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Deny-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email']) &&
             data.keys().size() <= 10 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 1000) &&
             (data.get('bio', '') is string && data.get('bio', '').size() <= 500) &&
             (data.get('createdAt', request.time) == request.time || data.createdAt == existing().createdAt);
    }

    // 3. User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().uid == request.auth.uid &&
                    incoming().createdAt == request.time;
                    
      allow update: if isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }
  }
}
